# --- Run the API (must be run from this backend/ folder so imports resolve) ---
#   cd architecture-adr/backend
#   uvicorn api.server:app --reload --host 127.0.0.1 --port 8000
# If you see WinError 10013 or "address already in use", something else is bound to that port.
#   netstat -ano | findstr ":8000"   then taskkill /PID <pid> /F
#   or use another port, e.g. --port 8001 and set frontend VITE_BACKEND_URL=http://127.0.0.1:8001
#
# AWS Bedrock (use default credential chain if keys omitted: ~/.aws/credentials, IAM role, etc.)
AWS_REGION=us-east-1
# Optional if not using default profile:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Required: Bedrock model id for your region / global inference
# Examples (verify in AWS console for your account/region):
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6-v1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
